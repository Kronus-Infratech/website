# ─── Database ───
DATABASE_URL="mongodb+srv://user:pass@cluster.mongodb.net/Kronus"

# ─── Server ───
PORT=4000
NODE_ENV=development

# ─── JWT ───
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ─── CORS ───
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# ─── Cloudflare R2 (S3-compatible) ───
R2_ACCOUNT_ID=""
R2_ACCESS_KEY=""
R2_SECRET_KEY=""
R2_BUCKET="kronus-uploads"
R2_PUBLIC_URL=""

# ─── Google OAuth ───
GOOGLE_CLIENT_ID=""

# ─── OTP Provider (console | twilio | msg91) ───
OTP_PROVIDER="console"

# Twilio (optional — only if OTP_PROVIDER=twilio)
TWILIO_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE=""

# ─── CRM System User ID (ObjectId of the CRM user that owns website-generated leads) ───
SYSTEM_USER_ID=""
